# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.rs]
indent_size = 4

[*.py]
indent_size = 4

[*.pbxproj]
indent_style = tab

[*.xccurrentversion]
indent_style = tab

[*.xcsettings]
indent_style = tab

[*.plist]
indent_style = tab

[*.xcscheme]
indent_size = unset

[*.swift]
indent_style = space
indent_size = 4
